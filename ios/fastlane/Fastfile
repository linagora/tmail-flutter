# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
update_fastlane

opt_out_usage
default_platform(:ios)
setup_ci if ENV['CI']

platform :ios do
  desc "Build development version"
  lane :dev do
    sync_code_signing(
      type: "development",
      git_private_key: ENV["APPLE_CERTIFICATES_SSH_KEY"]
    )
    build_app(
      scheme: "Runner",
      configuration: "Debug",
      workspace: "Runner.xcworkspace",
      export_method: "development",
    )
  end

  desc "Build and deploy release version"
  lane :release do
    # App Store Connect API setup
    app_store_connect_api_key(
      key_id: ENV["APPLE_KEY_ID"],
      issuer_id: ENV["APPLE_ISSUER_ID"],
      key_content: ENV["APPLE_KEY_CONTENT"]
    )
    sync_code_signing(
      type: "appstore",
      git_private_key: ENV["APPLE_CERTIFICATES_SSH_KEY"]
    )
    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )
    increment_version_number(
      version_number: last_git_tag.gsub("v", "").split("-").first
    )
    # Build, sign, and export IPA.
    # DART_OBFUSCATION and SPLIT_DEBUG_INFO are passed as xcodebuild build settings,
    # which Flutter's xcode_backend.sh picks up to obfuscate Dart code and write
    # debug symbols to the given path (required for Sentry Dart crash symbolication).
    # archive_path pins the xcarchive location so the CI Sentry upload step can
    # find dSYMs at a known path: build/ios/archive/Runner.xcarchive/dSYMs/
    #
    # File.expand_path with __dir__ resolves relative to this Fastfile's directory
    # (ios/fastlane/), so we go up 2 levels to reach the project root's build/ dir.
    symbols_path = File.expand_path("../../build/ios/outputs/symbols", __dir__)
    archive_path = File.expand_path("../../build/ios/archive/Runner.xcarchive", __dir__)
    build_app(
      scheme: "Runner",
      configuration: "Release",
      workspace: "Runner.xcworkspace",
      export_method: "app-store",
      export_options: {
        uploadBitcode: false,
        compileBitcode: false
      },
      xcargs: "DART_OBFUSCATION=true SPLIT_DEBUG_INFO=#{symbols_path}",
      archive_path: archive_path
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      ipa: "Runner.ipa"
    )
  end
end
