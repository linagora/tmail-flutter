pipeline {
    agent {
        label 'mobile'
    }

    options {
        timeout(time: 180, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        FLUTTER_VERSION = '3.38.9'
        FIREBASE_PROJECT_ID = 'twake-195010'
    }

    stages {
        stage('Prebuild') {
            steps {
                sh './scripts/prebuild.sh'
            }
        }

        stage('Run Patrol Mobile Integration Tests') {
            steps {
                withCredentials([file(credentialsId: 'firebase-testlab-sa', variable: 'GOOGLE_APPLICATION_CREDENTIALS')]) {
                    sh './scripts/patrol-integration-test-with-docker.sh'
                }
            }
        }
    }

    post {
        always {
            script {
                echo 'Running post-build cleanup...'

                // Tear down the backend Docker stack if it is still running.
                sh '''
                    cd backend-docker
                    docker compose down --remove-orphans 2>/dev/null || true
                '''
            }
            deleteDir() /* clean up our workspace */
        }
        failure {
            echo 'Pipeline failed. Review the console log for details.'
        }
    }
}
